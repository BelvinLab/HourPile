# --- Base de données PostgreSQL ---
# Copie ce fichier en ".env" et remplace les valeurs.
# Le fichier .env NE DOIT PAS être commité (il est dans .gitignore).

POSTGRES_USER=hourpile
POSTGRES_PASSWORD=change_me_en_local
POSTGRES_DB=hourpile

# URL construite à partir des variables ci-dessus.
# 'db' est le nom du service Postgres dans docker-compose (résolu par Docker).
DATABASE_URL=postgresql+psycopg://hourpile:change_me_en_local@db:5432/hourpile
